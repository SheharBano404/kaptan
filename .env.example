# --- Admin panel ---
# Password required to access /admin
ADMIN_PASSWORD=changeme
# Secret used to sign the admin session cookie (any long random string)
SESSION_SECRET=please-change-this-to-a-long-random-string

# --- Storage (optional) ---
# When connected to Vercel KV these are provided automatically by Vercel.
# Leave empty for local development — the app falls back to a JSON file in /.data
KV_REST_API_URL=
KV_REST_API_TOKEN=
